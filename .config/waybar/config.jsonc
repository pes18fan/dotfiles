{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["hyprland/workspaces", "clock"],
    "modules-center": ["hyprland/window"],
    "modules-right": 
        ["tray",
            "hyprland/language", "backlight", "pulseaudio",
            "network", "bluetooth", "battery", "idle_inhibitor", "power-profiles-daemon", "custom/power",
        ],
    "hyprland/workspaces": {
        "format": "{name}",
        "disable-scroll": true,
    },
    "hyprland/window": {
        "max-length": 60,
        "tooltip": false
    },
    "hyprland/language": {
        "format": "{short}",
    },
    "clock": {
        "format": "{:%a %d %b %H:%M}",
    },
    "tray": {
        "icon-size": 18
    },
    "battery": {
        "format": "{icon}",
        "format-icons": ["≤░Β╗", "≤░Β╜", "≤░Β┐", "≤░ΓΒ", "≤░Β╣"],
        "format-charging": "≤░ΓΕ",
        "interval": 30,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": true,
        "tooltip-format": "{capacity}%, {timeTo}"
    },
    "bluetooth": {
        "format": "ΎΛΦ",
        "tooltip-format": "{status}",
        "tooltip-format-connected": "{num_connections} connected\n{device_enumerate}",
        "on-click": "blueman-manager",   // or blueman-manager
    },
    "network": {
        "format-wifi": "≤░νρ",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "ΎΒ▒",
        "on-click": "foot nmtui", 
        "tooltip-format-wifi": "connection: wifi\nssid: {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "connection: ethernet\ninterface: {ifname}",
        "tooltip-format-disconnected": "disconnected"
    },
    "pulseaudio": {
        "format": "{volume} {icon} ",
        "format-alt-click": "click-right",
        "format-muted": "≤░ζθ",
        "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "tooltip": true,
        "tooltip-format": "{desc}",
        "reverse-scrolling": true
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
        "scroll-step": 1,
        "tooltip": false,
        "reverse-scrolling": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΑμ"
        },
        "tooltip": true,
        "tooltip-format-activated": "idle inhibitor {status}",
        "tooltip-format-deactivated": "idle inhibitor {status}"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "power profile: {profile}",
      "tooltip": true,
      "format-icons": {
        "performance": "ΎΔπ",
        "balanced": "ΎΚΟ",
        "power-saver": "ΎΒυ"
      }
    },
    "custom/power": {
        "format" : "έΠ╗",
        "on-click": "wlogout",
        "tooltip": false
    },
}

